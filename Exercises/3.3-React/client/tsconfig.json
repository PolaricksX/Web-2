{
	"compilerOptions": {
		"esModuleInterop": true, //allows default imports from CommonJS modules.
		"allowSyntheticDefaultImports": true, // lets TS treat modules like they have a default export (for compatibility).
		"allowImportingTsExtensions": true,//allows tsx extensions
		"target": "ESNext",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"allowJs": false,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"module": "ESNext",
		"moduleResolution": "Node",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx"
	},
	"include": ["src"]
}
